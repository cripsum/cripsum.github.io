php_value session.gc_maxlifetime 604800
php_value session.cookie_lifetime 604800
php_value session.gc_probability 1
php_value session.gc_divisor 1000

RewriteEngine On

RewriteRule ^cripsumpedia/?$ cripsumpedia/index.php [L,QSA]
RewriteRule ^cripsumpedia/home/?$ cripsumpedia/index.php [L,QSA]
RewriteRule ^cripsumpedia/search/?$ cripsumpedia/search.php [L,QSA]
RewriteRule ^cripsumpedia/admin/?$ cripsumpedia/admin.php [L,QSA]
RewriteRule ^cripsumpedia/editor/?$ cripsumpedia/editor.php [L,QSA]
RewriteRule ^cripsumpedia/(persone|people|eventi|events|meme|memes)/?$ cripsumpedia/category.php?category=$1 [L,QSA]
RewriteRule ^cripsumpedia/(persone|people|eventi|events|meme|memes)/([a-zA-Z0-9_-]+)/?$ cripsumpedia/entry.php?category=$1&slug=$2 [L,QSA]
RewriteRule ^(it|en)/cripsumpedia/?$ cripsumpedia/index.php?lang=$1 [L,QSA]
RewriteRule ^(it|en)/cripsumpedia/home/?$ cripsumpedia/index.php?lang=$1 [L,QSA]
RewriteRule ^(it|en)/cripsumpedia/search/?$ cripsumpedia/search.php?lang=$1 [L,QSA]
RewriteRule ^(it|en)/cripsumpedia/admin/?$ cripsumpedia/admin.php?lang=$1 [L,QSA]
RewriteRule ^(it|en)/cripsumpedia/editor/?$ cripsumpedia/editor.php?lang=$1 [L,QSA]
RewriteRule ^(it|en)/cripsumpedia/(persone|people|eventi|events|meme|memes)/?$ cripsumpedia/category.php?lang=$1&category=$2 [L,QSA]
RewriteRule ^(it|en)/cripsumpedia/(persone|people|eventi|events|meme|memes)/([a-zA-Z0-9_-]+)/?$ cripsumpedia/entry.php?lang=$1&category=$2&slug=$3 [L,QSA]

RewriteRule ^u/([a-zA-Z0-9_]{3,20})/?$ profile.php?username=$1 [L,QSA]

RewriteRule ^profile/([a-zA-Z0-9_]{3,20})/?$ profile.php?username=$1 [L,QSA]

RewriteRule ^it/u/([a-zA-Z0-9_]{3,20})/?$ profile.php?username=$1 [L,QSA]

RewriteRule ^user/([a-zA-Z0-9_]{3,20})/?$ profile.php?username=$1 [L,QSA]

RewriteRule ^it/game/?$ /it/game/lobby.php [L,QSA]
RewriteRule ^it/game/lobby/?$ /it/game/lobby.php [L,QSA]
RewriteRule ^it/game/arena/([0-9]+)/?$ /it/game/arena.php?match_id=$1 [L,QSA]


RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]

RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php [L]

RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

AddDefaultCharset UTF-8

<FilesMatch "^\.">
  Order allow,deny
  Deny from all
</FilesMatch>

RewriteRule ^user/([a-zA-Z0-9_]+)$ user.php?username=$1 [L,QSA]

ErrorDocument 404 /404.html
